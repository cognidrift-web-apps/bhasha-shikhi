# ============================================================
# BhashaShikhi - Environment Variables
# Copy this file to .env.local and fill in all values.
# Never commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
# Supabase (required)
# Project URL and keys from: https://app.supabase.com -> Settings -> API
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role key - server-side only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ------------------------------------------------------------
# WebSocket Relay (required)
# URL of the deployed Railway relay server.
# Local dev:  ws://localhost:8081
# Production: wss://your-relay.railway.app
# ------------------------------------------------------------
NEXT_PUBLIC_WS_RELAY_URL=ws://localhost:8081

# ------------------------------------------------------------
# Google Gemini (required)
# Used by Next.js API routes for scoring and Path B (text) chat.
# Get key from: https://aistudio.google.com/apikey
# ------------------------------------------------------------
GEMINI_API_KEY=AIza...

# ------------------------------------------------------------
# Microsoft Azure Speech (required for Microsoft TTS voices)
# Used by the /api/speech-token route to issue short-lived tokens
# to the browser.
# Get from: Azure portal -> Cognitive Services -> Speech
# ------------------------------------------------------------
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# ------------------------------------------------------------
# Admin Panel (required)
# ADMIN_ROUTE_SLUG  : URL path segment, e.g. "panel-abc123"
#                     Admin panel becomes accessible at /panel-abc123
# ADMIN_PASSWORD_HASH: bcrypt hash of the admin password
#   Generate: node -e "const b=require('bcryptjs');b.hash('YOUR_PASSWORD',10).then(h=>console.log(h))"
# ------------------------------------------------------------
ADMIN_ROUTE_SLUG=panel-change-this
ADMIN_PASSWORD_HASH=
